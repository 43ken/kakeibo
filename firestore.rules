rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: check if the requesting user belongs to this household ──────────
    // exists() is checked first to prevent a null-reference error when the
    // household document is temporarily unavailable during rule evaluation.
    function isHouseholdMember(householdId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/households/$(householdId))
        && request.auth.uid in
             get(/databases/$(database)/documents/households/$(householdId)).data.members;
    }

    // ── User profiles ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Invite codes ──────────────────────────────────────────────────────────
    match /inviteCodes/{code} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Households ────────────────────────────────────────────────────────────
    match /households/{householdId} {
      // Anyone signed in can create a new household (invite flow)
      allow create: if request.auth != null;
      // Only existing members can read / update the household document itself
      allow read, update, delete: if isHouseholdMember(householdId);

      // ── Config subcollection ─────────────────────────────────────────────
      // categories, settings, paymentMethods, budgets, etc.
      match /config/{docId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      // ── Transactions subcollection ────────────────────────────────────────
      // Both members can list (onSnapshot), get, create, update, delete
      match /transactions/{txId} {
        allow read, write: if isHouseholdMember(householdId);
      }
    }
  }
}
